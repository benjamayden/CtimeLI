# Countdown configuration — copy to .env and edit.
#   cp .env.example .env
# Every key is optional; shown values are the built-in defaults.
# Precedence: defaults < .env < process environment < CLI flags.
# See docs/configuration.md for the full reference.

# --- Stroke -----------------------------------------------------------------
STROKE_WIDTH=6.0                 # perimeter line thickness, px
RED_ZONE_FRACTION=0.05           # fraction-remaining where colour blends to red

# --- Edge glow (pulse) ------------------------------------------------------
PULSE_BEFORE_SECS=120.0          # glow window length before zero, s
PULSE_OPACITY_RAMP_SECS=10.0     # s to reach PULSE_MAX_OPACITY after window opens
PULSE_MAX_OPACITY=0.85           # peak glow alpha, 0-1
PULSE_DEPTH_MIN=10.0             # glow depth px at window start
PULSE_DEPTH_MAX=110.0            # glow depth px at zero
PULSE_RAMP=linear                # spread curve preset: linear | late
# PULSE_RAMP_POWER=1.0           # raw spread exponent; overrides PULSE_RAMP if set
PULSE_VISUAL_POWER=1.0           # extra draw-time spread shaping (legacy; 1=off)

# --- Window wiggle ----------------------------------------------------------
SHAKE_WIGGLE_SECONDS=3.0         # final N seconds the frontmost window wiggles
SHAKE_MAX_X=28.0                 # max horizontal offset, px
SHAKE_MAX_Y=28.0                 # max vertical offset, px
SHAKE_SPEED=10.0                 # base oscillation speed
SHAKE_SPEED_X=10.0               # x-axis frequency multiplier
SHAKE_SPEED_Y=10.0               # y-axis frequency multiplier
SHAKE_SMOOTH=14.0                # motion smoothing rate (higher = snappier)

# --- Block-on-end -----------------------------------------------------------
BLOCK_ON_END=false               # at zero, show stop overlay then tidy windows
BLOCK_END_DEFAULT=minimize       # action for foreground apps: minimize|hide|quit|skip
# Comma-separated app names. Aliases ok (chrome, vscode, iterm) — see docs.
BLOCK_END_MINIMIZE=
BLOCK_END_HIDE=
BLOCK_END_QUIT=
BLOCK_END_SKIP=

# --- Calendar (watch mode) --------------------------------------------------
CALENDAR_ENABLED=true            # auto-start timers from upcoming events
CALENDAR_POLL_SECONDS=15.0       # how often to re-query the calendar
CALENDAR_WINDOW_MINUTES=10.0     # only consider events starting within this window
CALENDAR_BLOCK_BEFORE_MINS=7.0   # block fires this many minutes before the event
CALENDAR_STROKE_R=0.30           # calendar-session stroke base colour
CALENDAR_STROKE_G=0.85
CALENDAR_STROKE_B=0.45
